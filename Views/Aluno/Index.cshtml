@{
    ViewData["Title"] = "Perfil do Aluno";
}

<div class="container mt-4">
    <h2>Perfil do Aluno</h2>
    <hr />
    <div class="card" style="width: 18rem;">
        <div class="card-body">
            <h5 class="card-title">@ViewBag.Nome</h5>
            <p class="card-text"><strong>Curso:</strong> @ViewBag.Curso</p>
            <p class="card-text"><strong>Semestre:</strong> @ViewBag.Semestre</p>
        </div>
    </div>
    <div class="mt-3">
        <a asp-controller="Aluno" asp-action="Detalhes" asp-route-id="1" class="btn btn-primary">Ver Detalhes (ID: 1)</a>
    </div>
</div>